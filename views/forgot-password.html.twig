{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
<section class="auth-page">
    <h1 class="auth-title">Mot de passe oublié</h1>
    <div class="auth-separator"></div>

    <div class="auth-container auth-container--center">
        <div class="auth-box">
            <p style="margin-bottom: 20px;">
                Renseignez votre adresse email pour effectuer une demande de réinitialisation.
            </p>

            {% if message %}
                <p class="auth-success">{{ message }}</p>
            {% endif %}

            <form method="POST" action="/forgot-password" class="auth-form">
                <input type="email" name="email" placeholder="saisissez votre e-mail" required>
                <button type="submit" class="btn-black full-width">Envoyer</button>
            </form>
        </div>
    </div>
</section>
{% endblock %}