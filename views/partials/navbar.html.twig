<header class="site-header">
    <nav class="navbar">
        <div class="navbar__logo">
            <a href="/">Web4all</a>
        </div>

        <button class="navbar__burger" id="burger" aria-label="Menu">
            <span></span>
            <span></span>
            <span></span>
        </button>

        <ul class="navbar__links" id="navbar-links">
            <li><a href="/">Accueil</a></li>
            <li><a href="/offers">Offres</a></li>
            <li><a href="/companies">Entreprise</a></li>
            {% if user %}
                <li><a href="/dashboard">Dashboard</a></li>
                <li><a href="/logout" class="btn-login">Se déconnecter</a></li>
            {% else %}
                <li><a href="/login" class="btn-login">Se connecter</a></li>
            {% endif %}
        </ul>
    </nav>
</header>

<script>
    document.getElementById('burger').addEventListener('click', function() {
        document.getElementById('navbar-links').classList.toggle('is-open');
    });
</script>